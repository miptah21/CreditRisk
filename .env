# === Credit Risk Decision System ===

# --- Model Settings ---
MODEL_VERSION=credit_v1
AUTO_DECLINE_THRESHOLD=0.15
MANUAL_REVIEW_THRESHOLD=0.08
FLOOR_APR=0.065

# --- Pricing Parameters ---
FUNDING_COST=0.055
OPEX_RATIO=0.02
TARGET_ROE=0.15
TIER1_RATIO=0.12

# --- Feature Store ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=credit_risk

# --- Monitoring ---
PSI_WARN_THRESHOLD=0.10
PSI_CRITICAL_THRESHOLD=0.25
AUC_MIN_THRESHOLD=0.72

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
